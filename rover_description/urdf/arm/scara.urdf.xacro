  <xacro:gripper parent_link="link5_link" x_1="0.00025" y_1="0.50000" z_1="-0.28960" x_2="0.00025" y_2="-0.50000" z_2="-0.28960" >
  </xacro:gripper>

  <transmission name="link1_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="link1_link_joint">
    <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="link1_motor">
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>
<transmission name="link2_trans">
