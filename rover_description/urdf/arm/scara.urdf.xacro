<robot name="robot" xmlns:xacro="http://wiki.ros.org/xacro">

<xacro:include filename="$(find rover_description)/urdf/arm/gripper.urdf.xacro"/>

<xacro:macro name="scara" params="parent_link x y z r p yw">
  <joint name="arm_base_link_joint" type="fixed">
    <origin rpy="${r} ${p} ${yw}" xyz="${x} ${y} ${z}"/>
    <parent link="${parent_link}"/>
    <child link="arm_base_link"/>
  </joint>
  <joint name="link1_link_joint" type="revolute">
    <limit lower="-3.05000" upper="3.05000" effort="1000" velocity="100.0"/>
    <origin rpy="0.00000 0.00000 0.00000" xyz="0.00703 0.00482 0.54623"/>
    <parent link="arm_base_link"/>
    <child link="link1_link"/>
    <axis xyz="0.00000 0.00000 1.00000"/>
  </joint>
  <joint name="link2_link_joint" type="revolute">
    <limit lower="-2.00000" upper="2.00000" effort="1000" velocity="100.0"/>
    <origin rpy="0.00000 0.00000 -3.14159" xyz="1.37657 -0.01190 0.19480"/>
    <parent link="link1_link"/>
    <child link="link2_link"/>
    <axis xyz="0.00000 0.00000 1.00000"/>
  </joint>
  <joint name="link3_link_joint" type="revolute">
