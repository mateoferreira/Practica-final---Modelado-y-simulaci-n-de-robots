    <origin rpy="0.00000 0.00000 0.00000" xyz="0.00446 0.00427 0.17412"/>
    <parent link="link3_link"/>
    <child link="link4_link"/>
    <axis xyz="0.00000 0.00000 1.00000"/>
  </joint>
  <joint name="link5_link_joint" type="fixed">
    <origin rpy="0.00000 0.00000 0.00000" xyz="0.00146 -0.00006 -0.89452"/>
    <parent link="link4_link"/>
    <child link="link5_link"/>
  </joint>
  <link name="arm_base_link">
    <collision name="base_collision">
      <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 0.00000"/>
      <geometry>
        <mesh filename="package://rover_description/meshes/dae/Cylinder.009.dae" scale="0.16927 0.16927 0.86707"/>
      </geometry>
    </collision>
    <inertial>
      <inertia ixx="1.54632" ixy="-0.00000" ixz="0.00000" iyy="1.54632" iyz="-0.00000" izz="0.08541"/>
      <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 0.00000"/>
      <mass value="6.00000"/>
    </inertial>
    <visual name="base">
      <material name="Material.009"/>
      <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 0.00000"/>
      <geometry>
        <mesh filename="package://rover_description/meshes/dae/Cylinder.009.dae" scale="0.16927 0.16927 0.86707"/>
      </geometry>
    </visual>
  </link>
  <link name="link1_link">
